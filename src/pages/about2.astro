---
// ─── ABOUT — PÁGINA SOBRE MÍ ──────────────────────────
//  Diseño minimalista enfocado en la lectura y la trayectoria.
//  Sin fotos redundantes, sin proyectos (ya tienen su espacio).
// ────────────────────────────────────────────────────────

import Layout from "../layouts/Layout.astro";

const curriculumUrl = "https://drive.google.com/file/d/1VBkWbmi9Pjx7BVrrSfI872oBf-D52YQD/view";
---

<Layout
  title="Sobre Mí | Jasmany Franco"
  description="Conoce más sobre la trayectoria de Jasmany Franco, Ingeniero en Sistemas y Full Stack Developer."
>
  <section class="w-full pt-32 pb-24 px-6 md:px-16 lg:px-24">
    <div class="max-w-3xl mx-auto">
      <!-- Redujimos el ancho máximo para una mejor lectura -->

      {/* ─── ENCABEZADO Y BIOGRAFÍA ─── */}
      <header class="mb-16">
        <h1
          class="text-[clamp(2.5rem,5vw,4rem)] font-bold text-[var(--hero-text)] mb-6 tracking-tight"
        >
          Jasmany <span class="text-[var(--accent)]">Franco</span>.
        </h1>

        <div class="prose prose-lg dark:prose-invert max-w-none text-[var(--hero-desc)] space-y-6">
          <p>
            Ingeniero en Sistemas con una sólida trayectoria en el sector público, especializado en
            la administración de infraestructura tecnológica y el desarrollo de software moderno. Mi
            pasión radica en transformar procesos manuales en soluciones digitales eficientes y
            escalables.
          </p>
          <p>
            Actualmente enfoco mi desarrollo en el ecosistema de <strong
              class="text-[var(--hero-text)] font-semibold">Node.js y React</strong
            >. Disfruto construyendo arquitecturas robustas y limpias, integrando sistemas
            complejos, y trabajando en entornos Linux. Soy un profesional orientado a la resolución
            de problemas bajo presión y con un fuerte compromiso por el aprendizaje autodidacta.
          </p>
        </div>

        <div class="mt-8 flex items-center gap-4">
          <a
            href={curriculumUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold border border-[var(--border)] bg-[var(--card)] text-[var(--hero-text)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all"
          >
            Ver Currículum
          </a>
          <a
            href="https://github.com/Darkjasmany"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold bg-[var(--accent)] text-white hover:brightness-110 transition-all"
          >
            GitHub
          </a>
        </div>
      </header>

      <hr class="border-[var(--border)] mb-16" />

      {/* ─── HABILIDADES TÉCNICAS (Minimalista) ─── */}
      <section class="mb-16">
        <h2 class="text-xl font-bold text-[var(--hero-text)] mb-6">Stack & Herramientas</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm">
          <div>
            <h3 class="font-semibold text-[var(--accent)] mb-2 uppercase tracking-widest text-xs">
              Frontend
            </h3>
            <p class="text-[var(--hero-desc)] leading-relaxed">
              React, TypeScript, Tailwind CSS, Astro, HTML5, CSS3, JavaScript.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-[var(--accent)] mb-2 uppercase tracking-widest text-xs">
              Backend & BD
            </h3>
            <p class="text-[var(--hero-desc)] leading-relaxed">
              Node.js, Express, Prisma, Sequelize, API REST, PostgreSQL, MySQL.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-[var(--accent)] mb-2 uppercase tracking-widest text-xs">
              Infraestructura
            </h3>
            <p class="text-[var(--hero-desc)] leading-relaxed">
              Linux, Docker, Proxmox, Git, Gestión de Redes y Servidores.
            </p>
          </div>
        </div>
      </section>

      {/* ─── TRAYECTORIA (Línea de tiempo minimalista) ─── */}
      <section>
        <h2 class="text-xl font-bold text-[var(--hero-text)] mb-8">Trayectoria</h2>

        <div class="space-y-12 border-l border-[var(--border)] ml-3 pl-8 relative">
          {/* Experiencia Laboral */}
          <div class="relative">
            <span
              class="absolute -left-[37px] top-1.5 w-3 h-3 rounded-full bg-[var(--accent)] ring-4 ring-[var(--bg)]"
            ></span>
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
              <h3 class="text-lg font-bold text-[var(--hero-text)]">
                Analista de Sistemas / Full Stack
              </h3>
              <time class="text-sm font-medium text-[var(--muted)]">Abril 2014 — Actualidad</time>
            </div>
            <p class="text-sm font-medium text-[var(--accent)] mb-4">
              GAD Municipal del cantón Naranjal
            </p>
            <ul
              class="space-y-3 text-sm text-[var(--hero-desc)] list-disc list-outside ml-4 marker:text-[var(--border)]"
            >
              <li>
                Liderazgo técnico del departamento, coordinación de equipos y asesoría estratégica
                en decisiones tecnológicas.
              </li>
              <li>
                Desarrollo de Software: Sistema de Gestión Documental (DMS) con Node.js, React y
                PostgreSQL. Desarrollo de Cash Management para integración con Banco de Pichincha y
                sistemas de ligas municipales.
              </li>
              <li>
                Infraestructura: Implementación de VPNs, administración de entornos virtualizados en
                Proxmox y control de asistencia (BioTime).
              </li>
              <li>
                Seguridad e integraciones: Gestión de certificados SSL, integración de pagos con el
                BCE y optimización de bases de datos.
              </li>
            </ul>
          </div>

          {/* Formación Universitaria */}
          <div class="relative">
            <span
              class="absolute -left-[37px] top-1.5 w-3 h-3 rounded-full bg-[var(--border)] ring-4 ring-[var(--bg)]"
            ></span>
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
              <h3 class="text-lg font-bold text-[var(--hero-text)]">
                Ingeniería en Sistemas Computacionales
              </h3>
              <time class="text-sm font-medium text-[var(--muted)]">Graduado</time>
            </div>
            <p class="text-sm font-medium text-[var(--accent)] mb-2">Universidad de Guayaquil</p>
            <p class="text-sm text-[var(--hero-desc)]">Registro SENESCYT: 1006-2017-1872471.</p>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>
