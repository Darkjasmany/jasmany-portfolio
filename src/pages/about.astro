---
import SkillCard from "../components/ui/SkillCard.astro";
import Title from "../components/ui/Title.astro";
import { skills } from "../data/specialtiesData";
import { stackData } from "../data/stackData";
import Layout from "../layouts/Layout.astro";

const curriculumUrl = "https://drive.google.com/file/d/1VBkWbmi9Pjx7BVrrSfI872oBf-D52YQD/view";

const categories = ["frontend", "backend_db", "devops"];

const categoryMeta: Record<string, { title: string; icon: string }> = {
  frontend: { title: "Frontend & Responsive Web Design", icon: "development" },
  backend_db: { title: "Backend & Bases de Datos", icon: "database" },
  devops: { title: "DevOps & Herramientas", icon: "infrastructure" },
};
---

<Layout
  title="Sobre Mí | Jasmany Franco"
  description="Conoce más sobre Jasmany Franco, Ingeniero en Sistemas y Full Stack Developer."
>
  <section id="section" class="w-full overflow-hidden transition-colors duration-300">
    <div
      class="z-10
      w-full max-w-7xl mx-auto
      px-4 sm:px-5 md:px-6 lg:px-10
      pt-24 md:pt-26 lg:pt-28
      pb-10 md:pb-16"
    >
      {/* ─── ENCABEZADO Y BIOGRAFÍA ─── */}
      <header class="mb-16">
        <Title title="Sobre" span="Mí" />
        <div
          class="my-6 prose prose-lg dark:prose-invert max-w-none text-[var(--hero-desc)] space-y-6 text-lg"
        >
          <p>
            Ingeniero en Sistemas con una sólida trayectoria en el sector público, especializado en
            la administración de infraestructura tecnológica y el desarrollo de software moderno. Mi
            pasión radica en transformar procesos manuales en soluciones digitales eficientes y
            escalables.
          </p>
          <p>
            Actualmente enfoco mi desarrollo en el ecosistema de <strong
              class="text-[var(--hero-text)] font-semibold">Node.js y React</strong
            >. Disfruto construyendo arquitecturas robustas y limpias, integrando sistemas
            complejos, y trabajando en entornos Linux. Soy un profesional orientado a la resolución
            de problemas bajo presión y con un fuerte compromiso por el aprendizaje autodidacta.
          </p>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <a
            href={curriculumUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold border border-[var(--border)] bg-[var(--card)] text-[var(--hero-text)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all"
          >
            Ver Currículum
          </a>
          <a
            href="https://github.com/Darkjasmany"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-semibold bg-[var(--accent)] text-white hover:brightness-110 transition-all"
          >
            GitHub
          </a>
        </div>
      </header>

      <hr class="border-[var(--border)] mb-16" />

      {/* ─── HABILIDADES TÉCNICAS ─── */}
      <div class="w-full overflow-hidden transition-colors duration-300 mb-16">
        <div
          class="flex-1 flex
            flex-col
            items-start
            gap-8
            md:gap-6
            select-none
            min-w-0"
        >
          <Title title="Especialización" span="Técnica" />
          <div
            class="grid
              grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
              gap-5 md:gap-6
              w-full"
          >
            {
              categories.map(cat => {
                const techs = stackData.filter(t => t.category === cat);
                const techNameString =
                  techs
                    .map(t => t.displayName || t.name.charAt(0).toUpperCase() + t.name.slice(1))
                    .join(", ") + ".";
                const meta = categoryMeta[cat];
                return (
                  <SkillCard title={meta.title} description={techNameString} icon={meta.icon} />
                );
              })
            }
          </div>
        </div>
      </div>

      {/* ─── HABILIDADES BLANDAS ─── */}
      <div class="w-full overflow-hidden transition-colors duration-300 mb-16">
        <div
          class="flex-1 flex
                flex-col
                items-start
                gap-8
                md:gap-6
                select-none
                min-w-0"
        >
          <Title title="Cómo" span="Trabajo" />
          <div
            class="grid
              grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
              gap-5 md:gap-6
              w-full"
          >
            {
              skills.map(skill => (
                <SkillCard title={skill.title} description={skill.description} path={skill.path} />
              ))
            }
          </div>
        </div>
      </div>

      <hr class="border-[var(--border)] mb-16" />
    </div>
  </section>
</Layout>
