---
import { workProcessSteps } from "../../data/workProcessData";
import Title from "../ui/Title.astro";
---

<section id="work-process" class="w-full overflow-hidden transition-colors duration-300">
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-5 md:px-6 lg:px-10 pb-10 md:pb-16">
    <div class="flex-1 flex flex-col items-start gap-8 md:gap-6 select-none min-w-0">
      <Title title="Flujo de " span="Trabajo" />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6 w-full">
        {
          workProcessSteps.map(step => (
            <div class="group relative p-6 rounded-xl border border-[var(--border)] bg-[var(--card)] shadow-md transition-all duration-300 hover:border-[var(--accent)] hover:-translate-y-1 overflow-hidden">
              <div class="absolute top-0 left-0 h-[3px] w-0 bg-[var(--accent)] transition-all duration-300 group-hover:w-full"></div>
              <div class="relative z-10">
                <span class="text-4xl md:text-5xl font-black text-[var(--accent)]/15 select-none">
                  {step.number}
                </span>
                <h3 class="text-lg font-bold text-[var(--hero-text)] mt-2 mb-2">
                  {step.title}
                </h3>
                <p class="text-sm leading-relaxed text-[var(--hero-desc)]">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
