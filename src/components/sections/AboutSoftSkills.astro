---
import Title from "../ui/Title.astro";
import SkillCard from "../ui/SkillCard.astro";
import { skills } from "../../data/specialtiesData";
---

<section class="w-full overflow-hidden transition-colors duration-300">
  <div class="z-10 w-full max-w-7xl mx-auto px-4 sm:px-5 md:px-6 lg:px-10 pb-10 md:pb-16">
    <div class="flex-1 flex flex-col items-start gap-8 md:gap-6 select-none min-w-0">
      <Title title="Cómo " span="Trabajo" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 w-full">
        {
          skills.map(skill => (
            <SkillCard title={skill.title} description={skill.description} path={skill.path} />
          ))
        }
      </div>
    </div>
  </div>
</section>
