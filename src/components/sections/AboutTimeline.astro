---
import { timelineData } from "../../data/timelineData";
import Title from "../ui/Title.astro";
---

<section class="w-full overflow-hidden transition-colors duration-300">
  <div class="z-10 w-full max-w-7xl mx-auto px-4 sm:px-5 md:px-6 lg:px-10 pb-10 md:pb-16">
    <div class="flex-1 flex flex-col items-start gap-8 md:gap-6 select-none min-w-0">
      <Title title="Experiencia " span="Profesional" />
      <div class="space-y-12 border-l border-[var(--border)] ml-3 pl-8 relative">
        {
          timelineData.map((entry) => (
            <div class="relative">
              <span
                class="absolute -left-[37px] top-1.5 w-3 h-3 rounded-full bg-[var(--accent)] ring-4 ring-[var(--bg)]"
              ></span>
              <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
                <h3 class="text-xl md:text-2xl font-bold text-[var(--hero-text)]">{entry.title}</h3>
                <time class="text-sm font-medium text-[var(--muted)]">{entry.period}</time>
              </div>
              {
                entry.company && (
                  <p class="text-sm font-medium text-[var(--accent)] mb-4">{entry.company}</p>
                )
              }
              {
                entry.description && (
                  <p class="text-sm text-[var(--hero-desc)] mb-4">{entry.description}</p>
                )
              }
              {
                entry.bullets.length > 0 && (
                  <ul
                    class="space-y-3 text-sm text-[var(--hero-desc)] list-disc list-outside ml-4 marker:text-[var(--border)]"
                  >
                    {entry.bullets.map((bullet) => <li>{bullet}</li>)}
                  </ul>
                )
              }
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
