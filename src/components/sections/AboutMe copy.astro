---
// src/components/SobreMi.astro
---

<section
  id="sobre-mi"
  class="w-full bg-[var(--bg)] py-16
                               transition-colors duration-300"
>
  <div class="max-w-6xl mx-auto px-6 md:px-16 lg:px-24">
    <!-- Tag -->
    <div class="flex items-center gap-2 mb-3">
      <span class="w-5 h-0.5 bg-[var(--accent)] rounded-full"></span>
      <span
        class="text-[11px] font-extrabold tracking-[2px]
                   uppercase text-[var(--accent)]"
      >
        Sobre mí
      </span>
    </div>

    <h2
      class="text-[clamp(2rem,4vw,3rem)] font-black tracking-[-1.5px]
               leading-[1.05] text-[var(--text)] mb-10"
    >
      El desarrollador<br />detrás del código
    </h2>

    <!-- Card principal: foto + bio -->
    <div
      class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-0
                rounded-2xl overflow-hidden border border-[var(--accent-border)]
                shadow-[var(--shadow)] mb-8"
    >
      <!-- Foto -->
      <div
        class="lg:w-[280px] bg-[var(--bg2)] flex items-center
                  justify-center p-6 border-b lg:border-b-0
                  lg:border-r border-[var(--accent-border)]"
      >
        <div
          class="w-[220px] h-[260px] rounded-xl overflow-hidden
                    border-2 border-[var(--accent-border)]
                    shadow-[4px_4px_0_var(--accent)]"
        >
          <img
            src="/Jasma.png"
            alt="Jasmany Franco"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>

      <!-- Texto -->
      <div class="bg-[var(--bg2)] p-8">
        <div class="flex items-center gap-2 mb-2">
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-4 h-4 text-[var(--accent)] flex-shrink-0"
          >
            <path
              d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"
            ></path>
          </svg>
          <span
            class="text-[13px] font-bold text-white
                       bg-[var(--accent)] px-2.5 py-0.5 rounded-md"
          >
            Naranjal, Ecuador 🇪🇨
          </span>
        </div>

        <h3
          class="text-[1.5rem] font-black tracking-[-0.8px]
                   text-[var(--text)] mb-4 mt-3"
        >
          Jasmany Franco
        </h3>

        <p class="text-[15px] text-[var(--muted)] leading-[1.85] mb-4">
          Ingeniero en Sistemas Computacionales con más de
          <strong class="text-[var(--text)] font-bold">10 años</strong>
          en el sector público ecuatoriano. Apasionado por construir soluciones digitales reales — tengo
          sistemas en producción, no solo tutoriales.
        </p>

        <p class="text-[15px] text-[var(--muted)] leading-[1.85]">
          Me despierto temprano a hacer ejercicios de lógica en
          <strong class="text-[var(--text)] font-bold">Exercism</strong>, aprendo continuamente y
          disfruto convertir procesos manuales en software eficiente.
        </p>

        <!-- Link "Ver más" estilo Lautaro -->
        <a
          href="#stack"
          class="inline-flex items-center gap-2 mt-6
                  text-[var(--accent)] font-bold text-[14px]
                  hover:gap-3 transition-all duration-200"
        >
          Ver mi stack
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Fila inferior: Experiencia + Formación -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Experiencia -->
      <div
        class="bg-[var(--bg2)] border border-[var(--border)]
                  rounded-2xl p-6 shadow-[var(--shadow)]
                  hover:border-[var(--accent-border)]
                  hover:drop-shadow-[3px_3px_0_var(--accent-border)]
                  transition-all duration-200"
      >
        <div class="flex items-center gap-2 mb-5">
          <div
            class="w-8 h-8 rounded-lg bg-[var(--accent-light)]
                      border border-[var(--accent-border)]
                      flex items-center justify-center flex-shrink-0"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[var(--accent)]">
              <path
                d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"
              ></path>
            </svg>
          </div>
          <h3
            class="text-[16px] font-black text-[var(--text)]
                     tracking-[-0.5px]"
          >
            Experiencia
          </h3>
        </div>

        <div class="space-y-5">
          <!-- Trabajo actual -->
          <div class="relative pl-4 border-l-2 border-[var(--accent)]">
            <div
              class="absolute -left-[5px] top-1 w-2 h-2
                        rounded-full bg-[var(--accent)]"
            >
            </div>
            <p class="text-[13px] font-bold text-[var(--accent)] mb-0.5">2014 — Actualidad</p>
            <p class="text-[14px] font-bold text-[var(--text)]">Analista de Sistemas</p>
            <p class="text-[13px] text-[var(--muted)]">GAD Municipal del cantón Naranjal</p>
            <p class="text-[12px] text-[var(--muted2)] mt-1 leading-[1.6]">
              Desarrollo de sistemas internos, administración Proxmox, VPNs, SSL, integración BCE,
              soporte técnico avanzado. Encargado de Dirección en múltiples periodos.
            </p>
          </div>

          <!-- Proyecto SelNic -->
          <div class="relative pl-4 border-l-2 border-[var(--border2)]">
            <div
              class="absolute -left-[5px] top-1 w-2 h-2
                        rounded-full bg-[var(--green)]"
            >
            </div>
            <p class="text-[13px] font-bold text-[var(--green)] mb-0.5">En producción</p>
            <p class="text-[14px] font-bold text-[var(--text)]">
              SelNic — Sistema de Gestión Documental
            </p>
            <p class="text-[13px] text-[var(--muted)]">
              Proyecto propio implementado en el municipio
            </p>
            <p class="text-[12px] text-[var(--muted2)] mt-1 leading-[1.6]">
              Sistema full stack con roles, permisos, historial de estados y carga de archivos. En
              uso diario.
            </p>
          </div>
        </div>
      </div>

      <!-- Formación -->
      <div
        class="bg-[var(--bg2)] border border-[var(--border)]
                  rounded-2xl p-6 shadow-[var(--shadow)]
                  hover:border-[var(--accent-border)]
                  hover:drop-shadow-[3px_3px_0_var(--accent-border)]
                  transition-all duration-200"
      >
        <div class="flex items-center gap-2 mb-5">
          <div
            class="w-8 h-8 rounded-lg bg-[var(--accent-light)]
                      border border-[var(--accent-border)]
                      flex items-center justify-center flex-shrink-0"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[var(--accent)]">
              <path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"
              ></path>
            </svg>
          </div>
          <h3
            class="text-[16px] font-black text-[var(--text)]
                     tracking-[-0.5px]"
          >
            Formación
          </h3>
        </div>

        <div class="space-y-5">
          <!-- Título universitario -->
          <div class="relative pl-4 border-l-2 border-[var(--accent)]">
            <div
              class="absolute -left-[5px] top-1 w-2 h-2
                        rounded-full bg-[var(--accent)]"
            >
            </div>
            <p class="text-[13px] font-bold text-[var(--accent)] mb-0.5">2017</p>
            <p class="text-[14px] font-bold text-[var(--text)]">Ing. en Sistemas Computacionales</p>
            <p class="text-[13px] text-[var(--muted)]">Universidad de Guayaquil</p>
            <p class="text-[12px] text-[var(--muted2)] mt-1">Reg. SENESCYT: 1006-2017-1872471</p>
          </div>

          <!-- Aprendizaje continuo -->
          <div class="relative pl-4 border-l-2 border-[var(--border2)]">
            <div
              class="absolute -left-[5px] top-1 w-2 h-2
                        rounded-full bg-[var(--amber)]"
            >
            </div>
            <p class="text-[13px] font-bold text-[var(--amber)] mb-0.5">Continuo — diario</p>
            <p class="text-[14px] font-bold text-[var(--text)]">Desarrollo web moderno</p>
            <p class="text-[13px] text-[var(--muted)]">Autodidacta · Exercism.io</p>
            <p class="text-[12px] text-[var(--muted2)] mt-1 leading-[1.6]">
              Node.js, TypeScript, React, Prisma, Docker, Astro. Práctica diaria de algoritmos y
              lógica.
            </p>
          </div>

          <!-- Inglés -->
          <div class="relative pl-4 border-l-2 border-[var(--border2)]">
            <div
              class="absolute -left-[5px] top-1 w-2 h-2
                        rounded-full bg-[var(--muted2)]"
            >
            </div>
            <p class="text-[13px] font-bold text-[var(--muted)] mb-0.5">En progreso</p>
            <p class="text-[14px] font-bold text-[var(--text)]">Inglés técnico</p>
            <p class="text-[12px] text-[var(--muted2)] mt-1">
              Lectura y comprensión técnica · aprendizaje activo
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
