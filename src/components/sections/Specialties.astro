---
import { specialtiesData } from "../../data/specialtiesData";
import SpecialtyCard from "../ui/SpecialtyCard.astro";
---

<section
  id="specialties"
  class="w-full min-h-screen overflow-x-hidden transition-colors duration-300"
>
  <!-- <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-10"> -->
  <!-- class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-5 md:px-6 lg:px-10 pt-24 md:pt-26 lg:pt-28
  pb-10 md:pb-16 flex flex-col lg:flex-row items-center justify-center gap-8 md:gap-10 lg:gap-20 xl:gap-24" -->
  <div
    class="relative z-10
            w-full max-w-7xl mx-auto
            px-4 sm:px-5 md:px-6 lg:px-10
            pt-0
            pb-10 md:pb-16"
  >
    <div class="flex-1 flex flex-col items-start gap-8 md:gap-6 select-none min-w-0">
      <div class="">
        <h2
          class="text-[clamp(2.5rem,5vw,3.5rem)] font-semibold text-[var(--hero-text)] mb-1 tracking-tight"
        >
          Áreas de
          <span class="text-[var(--accent)]">Especialidad</span>
        </h2>

        <div class="w-24 h-1 rounded-full bg-[var(--accent)] opacity-70"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 w-full">
        {
          specialtiesData.map(data => (
            <SpecialtyCard title={data.title} description={data.description} icon={data.icon} />
          ))
        }
      </div>
    </div>
  </div>
</section>
