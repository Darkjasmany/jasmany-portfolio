---
import { socialData } from "../../data/socialData";
import SocialIcon from "../ui/SocialIcon.astro";

const curriculumUrl = "https://drive.google.com/file/d/1VBkWbmi9Pjx7BVrrSfI872oBf-D52YQD/view";
---

<section
  id="contact"
  class="relative
    z-10
    w-full
    max-w-7xl
    mx-auto
    px-4
    sm:px-5
    md:px-6
    lg:px-10
    pb-10
    md:pb-16
    overflow-hidden
    transition-colors
    duration-300"
>
  <!-- <section id="contact" class="relative w-full py-24 md:py-32 px-6 md:px-16 lg:px-24 overflow-hidden"> -->
  <div class="max-w-6xl
      mx-auto
      text-center">
    <!-- TÍTULO -->
    <h2 class="text-[clamp(2rem,4vw,3rem)] font-bold text-[var(--hero-text)] mb-4">
      &iquest;Trabajamos <span class="text-[var(--accent)]">juntos</span>?
    </h2>
    <div class="w-16 h-1 bg-[var(--accent)] rounded-full mx-auto mb-6"></div>

    <p class="text-lg text-[var(--hero-desc)] max-w-xl mx-auto mb-8">
      Estoy disponible para nuevos proyectos, colaboraciones y oportunidades laborales. Si tienes
      una idea o proyecto en mente, &iexcl;hablemos!
    </p>

    <!-- REDES SOCIALES -->
    <div class="flex justify-center gap-4 flex-wrap mb-8">
      {
        socialData.map(data =>
          data.type === "email" ? (
            <SocialIcon href={data.link} ariaLabel={data.name}>
              <g
                class="stroke-current fill-none group-hover:stroke-[var(--accent)]"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 7l-10 7L2 7" />
              </g>
            </SocialIcon>
          ) : (
            <SocialIcon href={data.link} ariaLabel={data.name} path={data.path} />
          )
        )
      }
    </div>

    <!-- BOTONES -->
    <div class="flex flex-wrap justify-center gap-4">
      <!-- Descargar CV -->
      <a
        href={curriculumUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-base font-semibold
          bg-[var(--accent)] text-white
          hover:brightness-110 hover:shadow-lg hover:shadow-[var(--accent)]/25
          active:scale-95 transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Descargar Currículum
      </a>

      <!-- Enviar Email -->
      <a
        href="mailto:jasmanyfranco@gmail.com"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-base font-semibold
          border-2 border-[var(--accent)] text-[var(--accent)]
          hover:bg-[var(--accent)] hover:text-white
          active:scale-95 transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        Enviar Email
      </a>
    </div>
  </div>
</section>
