---
import { HiArrowRight } from "react-icons/hi";
import { socialData } from "../../data/socialData";
import Card from "../ui/Card.astro";
import SocialIcon from "../ui/SocialIcon.astro";
import TypeEffect from "../ui/TypeEffect";
---

<header
  id="inicio"
  class="w-full min-h-screen flex items-center justify-center overflow-hidden transition-colors duration-300"
>
  <div
    class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-16 lg:px-24 pt-28 pb-16 flex flex-col lg:flex-row items-center justify-center gap-24 xl:gap-28"
  >
    <!-- IZQUIERDA -->
    <div class="flex-1 flex flex-col items-start gap-6 select-none">
      <div>
        <h1
          class="font-semibold leading-none text-[var(--hero-text)] text-[clamp(2.8rem,6vw,4.8rem)]"
        >
          Jasmany Franco
        </h1>

        <!-- Rol animado con Typewriter-->
        <h2
          class="font-semibold leading-tight text-[var(--hero-text)] text-[clamp(1.6rem,3vw,2.5rem)] flex items-center gap-3"
        >
          <span class="opacity-30">|</span>
          <TypeEffect client:visible />
        </h2>
      </div>

      <p class="text-[var(--hero-desc)] max-w-120 text-lg leading-relaxed opacity-80">
        Ingeniero en Sistemas con más de 10 años en el sector público ecuatoriano, enfocado en
        desarrollo web moderno con Node.js, TypeScript y React. Construyo sistemas reales que
        resuelven problemas reales.
      </p>

      <!-- LINK FIXED -->
      <a
        href="#sobre-mi"
        class="group inline-flex items-center gap-2 text-base font-semibold transition-colors duration-200 ease-out text-[var(--hero-text)] hover:text-[var(--accent)] opacity-90 hover:opacity-100"
      >
        Ver más sobre mí
        <HiArrowRight
          className="text-xl transition-transform duration-300 ease-out group-hover:translate-x-2"
          size={18}
        />
      </a>

      <!-- CURRICULUM -->
      <a
        href="https://drive.google.com/file/d/1VBkWbmi9Pjx7BVrrSfI872oBf-D52YQD/view"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-base font-semibold bg-[var(--accent)] text-white hover:shadow-lg hover:shadow-[var(--accent)]/25 active:scale-95 transition-all duration-200"
        ><!-- Ícono de descarga (SVG inline) -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Mi Curriculum</a
      >

      <!-- SOCIAL -->
      <div class="flex gap-4 flex-wrap">
        {
          socialData.map(data =>
            data.type === "email" ? (
              <SocialIcon href={data.link} ariaLabel={data.name}>
                <g
                  class="stroke-current fill-none group-hover:stroke-[var(--accent)]"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="M22 7l-10 7L2 7" />
                </g>
              </SocialIcon>
            ) : (
              <SocialIcon href={data.link} ariaLabel={data.name} path={data.path} />
            )
          )
        }
      </div>
    </div>

    <!-- DERECHA -->
    <Card />
  </div>
</header>
