---
import SpecialtyCard from "../ui/SpecialtyCard.astro";
---

<section
  id="specialties"
  class="w-full flex items-center justify-center overflow-hidden transition-colors duration-300"
>
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-16 lg:px-24 pt-32 pb-24">
    <div class="mb-40 md:mb-56">
      <h2
        class="text-[clamp(2.5rem,5vw,3.5rem)] font-extrabold text-[var(--hero-text)] mb-6 tracking-tight"
      >
        Especialidades <span class="text-[var(--accent)]">Principales</span>
      </h2>
      <div class="w-24 h-1.5 bg-[var(--accent)] rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <SpecialtyCard
        title="Full Stack"
        description="Node.js + React + TypeScript + PostgreSQL. Aplicaciones web completas, APIs REST y frontend moderno de principio a fin."
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </SpecialtyCard>

      <SpecialtyCard
        title="Automatización"
        description="Sistemas que eliminan procesos manuales. Gestión documental (DMS), digitalización de trámites y workflows administrativos."
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
      </SpecialtyCard>

      <SpecialtyCard
        title="Infraestructura"
        description="Proxmox, Docker, VPN, Linux. Ambientes virtualizados, conectividad segura y administración de servidores."
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="3" width="20" height="14" rx="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      </SpecialtyCard>

      <SpecialtyCard
        title="Bases de Datos"
        description="MySQL, PostgreSQL, optimización de consultas. Integración con el Banco Central (BCE) y seguridad SSL."
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
          <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
          <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
        </svg>
      </SpecialtyCard>
    </div>
  </div>
</section>
