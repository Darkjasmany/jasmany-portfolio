---
import Title from "../ui/Title.astro";

interface Certification {
  title: string;
  issuer: string;
  date: string;
  credentialUrl?: string;
}

const certifications: Certification[] = [
  // Agrega aquí tus certificados cuando los tengas:
  // { title: "React + TypeScript", issuer: "Udemy", date: "2025", credentialUrl: "https://..." },
  // { title: "JavaScript Moderno", issuer: "Platzi", date: "2024", credentialUrl: "https://..." },
];
---

<section id="certifications" class="w-full overflow-hidden transition-colors duration-300">
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-5 md:px-6 lg:px-10 pb-10 md:pb-16">
    <div class="flex-1 flex flex-col items-start gap-8 md:gap-6 select-none min-w-0">
      <Title title="Certificaciones" span="" />

      {
        certifications.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 w-full">
            {
              certifications.map(cert => (
                <a
                  href={cert.credentialUrl || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group relative p-5 rounded-xl border border-[var(--border)] bg-[var(--card)] shadow-md transition-all duration-300 hover:border-[var(--accent)] hover:-translate-y-1 hover:shadow-lg overflow-hidden"
                >
                  <div class="absolute top-0 left-0 h-[3px] w-0 bg-[var(--accent)] transition-all duration-300 group-hover:w-full"></div>
                  <div class="relative z-10">
                    <p class="text-base font-bold text-[var(--hero-text)] mb-1">{cert.title}</p>
                    <p class="text-sm text-[var(--accent)]">{cert.issuer}</p>
                    <p class="text-xs text-[var(--muted)] mt-1">{cert.date}</p>
                  </div>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="w-full text-center py-12 rounded-xl border border-dashed border-[var(--border)] bg-[var(--card)]">
            <p class="text-[var(--muted)] text-base mb-2">
              Próximamente — certificados en proceso
            </p>
            <p class="text-sm text-[var(--muted2)]">
              Mis certificaciones de cursos serán publicadas aquí.
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>
