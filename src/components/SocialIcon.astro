---
interface Props {
  href: string;
  ariaLabel: string;
}

const { href, ariaLabel } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ariaLabel}
  class="group w-[46px] h-[46px] rounded-full border-2 border-current flex items-center justify-center text-[var(--hero-text)] dark:text-white/90 opacity-90 hover:opacity-100 transition-all duration-300 ease-out hover:text-[#00a3ff] hover:border-[#00a3ff] hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(0,163,255,0.35)] backdrop-blur-sm"
>
  <svg
    viewBox="0 0 24 24"
    class="w-6 h-6 fill-current transition-all duration-300 ease-out group-hover:scale-110 group-hover:fill-[#00a3ff]"
  >
    <slot />
  </svg>
</a>
