---
interface Props {
  href: string;
  ariaLabel: string;
  path?: string;
}

const { href, ariaLabel, path } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ariaLabel}
  class="group w-11.5 h-11.5 rounded-full border-2 border-current flex items-center justify-center text-[var(--hero-text)] opacity-90 hover:opacity-100
  transition-all duration-300 ease-out hover:text-[var(--accent)] hover:border-[var(--accent)] hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
  backdrop-blur-sm"
>
  <svg
    viewBox="0 0 24 24"
    class="w-6 h-6 fill-current transition-all duration-300 ease-out
    group-hover:scale-110 group-hover:fill-[var(--accent)]"
  >
    {path ? <path d={path} /> : <slot />}
  </svg>
</a>
