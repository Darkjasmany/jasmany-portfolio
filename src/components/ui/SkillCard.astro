---
interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
---

<div class="flex items-start gap-3 p-4 rounded-xl border border-[var(--border)] bg-[var(--card)]">
  <div
    class="w-8 h-8 rounded-lg bg-[var(--accent-light)] flex items-center justify-center shrink-0 mt-0.5"
  >
    <svg
      class="w-4 h-4 text-[var(--accent)]"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d={path}></path>
    </svg>
  </div>
  <div>
    <h4 class="text-sm font-bold text-[var(--hero-text)]">{title}</h4>
    <p class="text-xs text-[var(--hero-desc)] mt-0.5">
      {description}
    </p>
  </div>
</div>
