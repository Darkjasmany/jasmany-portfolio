---
import HoverCard from "./HoverCard.astro";
import { getSvgContent } from "../../utils/svg";

interface Props {
  title: string;
  description: string;
  path?: string;
  icon?: string;
}

const { title, description, icon, path } = Astro.props;
const svgRaw = icon ? getSvgContent(icon) : null;
---

<HoverCard>
  <div class="flex items-start gap-3 p-4">
    <div
      class:list={[
        "relative z-10 flex shrink-0 items-center justify-center w-10 h-10 rounded-lg",
        svgRaw ? "bg-transparent" : "bg-[var(--accent-light)]",
      ]}
    >
      {
        svgRaw ? (
          <div
            class="w-8 h-8 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full"
            set:html={svgRaw}
          />
        ) : path ? (
          <svg
            class="w-5 h-5 text-[var(--accent)]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={path} />
          </svg>
        ) : null
      }
    </div>

    <div class="flex flex-col">
      <h4 class="text-base font-bold text-[var(--hero-text)]">{title}</h4>
      <p class="text-sm text-[var(--hero-desc)] mt-0.5 leading-relaxed">
        {description}
      </p>
    </div>
  </div>
</HoverCard>
