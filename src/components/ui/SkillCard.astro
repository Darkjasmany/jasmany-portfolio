---
interface Props {
  title: string;
  description: string;
  path?: string;
  icon?: string;
}

const { title, description, icon, path } = Astro.props;

// 1. Importamos todos los SVGs de la carpeta de forma dinámica
const githubSvgs = import.meta.glob("/public/svg/*.svg", { as: "raw" });
const svgPath = `/public/svg/${icon}.svg`;

// 2. Obtenemos el contenido crudo del SVG
const svgRaw = githubSvgs[svgPath] ? await githubSvgs[svgPath]() : "";
---

<div
  class="group relative flex items-start gap-3 p-4 rounded-xl border border-[var(--border)] bg-[var(--card)] shadow-md transition-all duration-300 hover:border-[var(--accent)] hover:-translate-y-1 hover:shadow-lg overflow-hidden"
>
  <!-- Línea superior animada -->
  <div
    class="absolute top-0 left-0 h-[3px] w-0 bg-[var(--accent)] transition-all duration-300 group-hover:w-full z-0"
  >
  </div>

  <!-- Glow suave -->
  <div
    class="absolute
      inset-0
      bg-gradient-to-br
      from-[var(--accent)]/5
      to-transparent
      opacity-0
      group-hover:opacity-100
      transition-opacity
      duration-300
      pointer-events-none"
  >
  </div>

  <!-- Icono -->
  <div
    class:list={[
      "relative z-10 flex shrink-0 items-center justify-center w-10 h-10 rounded-lg",
      // MAGIA AQUÍ: Si existe svgRaw es transparente, si no, usa el fondo de color
      svgRaw ? "bg-transparent" : "bg-[var(--accent-light)]",
    ]}
  >
    {
      svgRaw ? (
        <div
          class="w-8 h-8 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full"
          set:html={svgRaw}
        />
      ) : path ? (
        <svg
          class="w-5 h-5 text-[var(--accent)]"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d={path} />
        </svg>
      ) : null
    }
  </div>

  <!-- Contenedor de Texto -->
  <div class="relative z-10 flex flex-col">
    <h4 class="text-base font-bold text-[var(--hero-text)]">{title}</h4>
    <p class="text-sm text-[var(--hero-desc)] mt-0.5 leading-relaxed">
      {description}
    </p>
  </div>
</div>
