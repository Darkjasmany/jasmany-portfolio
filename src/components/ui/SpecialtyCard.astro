---
import HoverCard from "./HoverCard.astro";
import { getSvgContent } from "../../utils/svg";

interface Props {
  title: string;
  description: string;
  longDescription: string;
  icon: string;
  category?: string;
}

const { title, description, icon, category = "", longDescription } = Astro.props;
const svgRaw = getSvgContent(icon);
---

<HoverCard>
  <div class="p-5 md:p-6">
    {
      category && (
        <p
          class="text-[11px] uppercase tracking-[0.25em] text-[var(--accent)] font-semibold mb-3"
        >
          {category}
        </p>
      )
    }

    <div class="flex items-center gap-4 mb-3">
      {
        svgRaw && (
          <div
            class="w-8 h-8 shrink-0 flex items-center justify-center text-[var(--accent)] transition-transform duration-300 group-hover:scale-110 [&>svg]:w-full [&>svg]:h-full"
            set:html={svgRaw}
          />
        )
      }

      <h3
        class="text-xl md:text-2xl font-bold leading-tight text-[var(--hero-text)]"
      >
        {title}
      </h3>
    </div>

    <p class="text-sm md:hidden leading-relaxed text-[var(--hero-desc)]">
      {description}
    </p>

    <p class="hidden md:block text-base leading-relaxed text-[var(--hero-desc)]">
      {longDescription}
    </p>
  </div>
</HoverCard>
