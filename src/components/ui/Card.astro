---
import { Image } from "astro:assets";
// Importa la imagen localmente (asumiendo que está en src/assets/)
// Si está en public/, usa "/Jasma.png" directamente en el src del componente
import jasmaImage from "../../assets/images/Jasma.png";
---

<div class="hidden lg:flex items-center justify-center shrink-0" style="perspective: 1400px;">
  <div
    id="card-wrapper"
    class="relative w-70 h-85 animate-float
           transition-transform duration-300 ease-out"
    style="transform-style: preserve-3d;"
  >
    <!-- Marco trasero 2 — más rotado, más oscuro -->
    <div
      class="absolute inset-0 rounded-2xl"
      style="
        background: rgba(0,0,0,0.22);
        transform: rotate(12deg) translateX(18px) translateY(-8px) translateZ(-30px);
        border-radius: 16px;
      "
    >
    </div>

    <!-- Marco trasero 1 — menos rotado -->
    <div
      class="absolute inset-0 rounded-2xl"
      style="
        background: rgba(0,0,0,0.13);
        transform: rotate(6deg) translateX(8px) translateY(-3px) translateZ(-15px);
        border-radius: 16px;
      "
    >
    </div>

    <!-- Tarjeta principal -->
    <div
      id="card"
      class="relative z-10 w-full h-full rounded-2xl overflow-hidden
             border border-white/30
             shadow-[0_25px_70px_rgba(0,0,0,0.25)]"
      style="transform: translateZ(0px); transform-style: preserve-3d;"
    >
      <Image
        src={jasmaImage}
        alt="Jasmany Franco"
        width={280}
        height={340}
        class="w-full h-full object-cover object-top"
      />

      <!-- Glow dinámico al hover -->
      <div
        id="glow"
        class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200"
      >
      </div>

      <!-- Shine efecto vidrio -->
      <div
        id="shine"
        class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200"
      >
      </div>

      <!-- Label Ecuador -->
      <div
        class="absolute bottom-0 left-0 right-0 py-2 text-center
                  bg-black/45 backdrop-blur-sm text-white text-xs font-bold tracking-wide"
      >
        📍 Naranjal, Ecuador 🇪🇨
      </div>
    </div>
  </div>
</div>

<script>
  const wrapper = document.getElementById("card-wrapper") as HTMLElement;
  const card = document.getElementById("card") as HTMLElement;
  const glow = document.getElementById("glow") as HTMLElement;
  const shine = document.getElementById("shine") as HTMLElement;

  // Pausar float en hover para que no pelee con el 3D
  wrapper.addEventListener("mouseenter", () => {
    wrapper.style.animationPlayState = "paused";
  });
  wrapper.addEventListener("mouseleave", () => {
    wrapper.style.animationPlayState = "running";
    // Reset
    wrapper.style.transform = "";
    card.style.transform = "translateZ(0px)";
    glow.style.opacity = "0";
    shine.style.opacity = "0";
  });

  wrapper.addEventListener("mousemove", (e: MouseEvent) => {
    const rect = wrapper.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;

    const rotX = -((y - centerY) / centerY) * 12;
    const rotY = ((x - centerX) / centerX) * 12;

    wrapper.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.04)`;

    // Glow
    glow.style.opacity = "1";
    glow.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(0,163,255,0.25), transparent 65%)`;

    // Shine
    shine.style.opacity = "0.55";
    shine.style.background = `linear-gradient(${120 + rotY * 2}deg, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0.05) 40%, transparent 60%)`;
  });
</script>
