---
import { socialData } from "../data/socialData";
import Card from "./Card.astro";
import TypeEffect from "./home/TypeEffect";
import SocialIcon from "./SocialIcon.astro";
---

<header
  id="inicio"
  class="w-full min-h-screen flex items-center justify-center overflow-hidden transition-colors duration-300"
>
  <div
    class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-16 lg:px-24 pt-28 pb-16 flex flex-col lg:flex-row items-center justify-center gap-16"
  >
    <!-- IZQUIERDA -->
    <div class="flex-1 flex flex-col items-start gap-6 select-none">
      <div>
        <!-- Nombre -->
        <h1 class="font-bold leading-[0.95] text-(--hero-text) text-[clamp(2.8rem,6vw,4.8rem)]">
          Jasmany Franco
        </h1>

        <!-- Rol -->
        <h2
          class="font-semibold leading-tight text-(--hero-text) text-[clamp(1.6rem,3vw,2.5rem)] flex items-center gap-3"
        >
          <span class="opacity-30">|</span>
          <TypeEffect client:visible />
        </h2>
      </div>

      <!-- Descripción del Rol -->
      <p class="text-(--hero-desc) max-w-130 text-[clamp(0.9rem,1.4vw,3.8rem)] leading-relaxed">
        Ingeniero en Sistemas con más de 10 años en el sector público ecuatoriano, enfocado en
        desarrollo web moderno con Node.js, TypeScript y React. Construyo sistemas reales que
        resuelven problemas reales.
      </p>

      <!-- Íconos sociales -->
      <div class="flex gap-4 flex-wrap">
        {
          socialData.map(data =>
            data.type === "email" ? (
              <SocialIcon href={data.link} ariaLabel={data.name}>
                <g
                  class="stroke-current fill-none group-hover:stroke-[#00a3ff]"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="M22 7l-10 7L2 7" />
                </g>
              </SocialIcon>
            ) : (
              <SocialIcon href={data.link} ariaLabel={data.name} path={data.path} />
            )
          )
        }
      </div>
    </div>

    <!-- DERECHA — foto con marcos -->
    <Card />
  </div>
</header>
