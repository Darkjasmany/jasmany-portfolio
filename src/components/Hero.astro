---
import Card from "./Card.astro";
---

<!-- class="relative w-full min-h-screen flex items-center justify-center overflow-hidden transition-colors duration-300" -->
<header
  id="inicio"
  class="w-full min-h-screen flex items-center justify-center overflow-hidden transition-colors duration-300"
>
  <!-- Contenido — padding-top compensa el nav fijo -->
  <div
    class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-16 lg:px-24 pt-28 pb-16 flex flex-col lg:flex-row items-center justify-center gap-12"
  >
    <!-- IZQUIERDA -->
    <div class="flex-1 flex flex-col items-start">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-8
                  bg-[var(--green-bg)] border border-[var(--green)]/20
                  text-[var(--green)] text-[13px] font-semibold"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--green)] animate-pulse"></span>
        Disponible para proyectos
      </div>

      <!-- Nombre -->
      <h1
        class="font-bold leading-none text-[var(--hero-text)] mb-1 text-[clamp(2.8rem,6vw,4.8rem)]"
      >
        Jasmany Franco
      </h1>

      <!-- Rol -->
      <h2
        class="font-semibold leading-none text-[var(--hero-text)] mb-8 text-[clamp(2rem,4.5vw,4.8rem)]"
      >
        <span class="opacity-35 mr-5">|</span>
        Full Stack Developer
      </h2>

      <!-- Descripción -->
      <p class="text-[var(--hero-desc)] max-w-[540px] mb-10 text-[clamp(0.9rem,1.4vw,3.8rem)]">
        Ingeniero en Sistemas con más de 10 años en el sector público ecuatoriano, enfocado en
        desarrollo web moderno con Node.js, TypeScript y React. Construyo sistemas reales que
        resuelven problemas reales — desde gestión documental municipal hasta validación biométrica
        en ligas de fútbol.
      </p>

      <!-- Íconos sociales -->
      <div class="flex gap-4 flex-wrap">
        <a
          href="https://github.com/Darkjasmany"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/in/jasmany-developer/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>

        <a
          href="https://www.facebook.com/jasmany.franco"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M15 3h3V0h-3c-2.21 0-4 1.79-4 4v3H8v4h3v13h4V11h3.64l.36-4H15V4c0-.55.45-1 1-1z"
            ></path>
          </svg>
        </a>

        <a
          href="https://www.instagram.com/jasmanyfranco/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm10 2a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h10zm-5 3.2A4.8 4.8 0 1 0 16.8 12 4.8 4.8 0 0 0 12 7.2zm0 2A2.8 2.8 0 1 1 9.2 12 2.8 2.8 0 0 1 12 9.2zm4.8-.9a1.2 1.2 0 1 0 1.2-1.2 1.2 1.2 0 0 0-1.2 1.2z"
            ></path>
          </svg>
        </a>

        <a
          href="https://twitter.com/darkjasmany"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M18.901 1.153h3.68l-8.04 9.19L24 22.847h-7.406l-5.8-7.59-6.64 7.59H.474l8.6-9.83L0 1.153h7.594l5.243 6.932 6.064-6.932zm-1.29 19.694h2.04L6.486 2.998H4.306l13.305 17.849z"
            ></path>
          </svg>
        </a>

        <a
          href="mailto:jasmanyfranco@gmail.com"
          aria-label="Email"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 stroke-current fill-none
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:stroke-[#00a3ff]"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="M22 7l-10 7L2 7"></path>
          </svg>
        </a>

        <a
          href="https://wa.me/593967537415"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="group w-[52px] h-[52px] rounded-full border-2
         border-current flex items-center justify-center
         text-[var(--hero-text)] dark:text-white/80
         opacity-70 hover:opacity-100
         transition-all duration-300 ease-out
         hover:text-[#00a3ff] hover:border-[#00a3ff]
         hover:-translate-y-1
         hover:shadow-[0_0_15px_rgba(0,163,255,0.35)]
         backdrop-blur-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-6 h-6 fill-current
           transition-all duration-300 ease-out
           group-hover:scale-110 group-hover:fill-[#00a3ff]"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
    <!-- DERECHA — foto con marcos -->
    <Card />
  </div>
</header>
