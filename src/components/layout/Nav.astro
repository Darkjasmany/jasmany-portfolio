---
import { navLinks } from "../../data/navigationData";
import ThemeToggle from "../ui/ThemeToggle";
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-500 h-17.5 flex justify-center items-center bg-(--hero-bg)/30 backdrop-blur-md border-b border-transparent transition-all duration-300"
>
  <div class="w-full max-w-7xl mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="text-3xl font-black tracking-tighter text-(--hero-text) transition-transform hover:scale-105 select-none"
    >
      Jasmany<span class="text-[var(--accent)]">Dev</span>
    </a>

    <!-- Desktop nav + toggle -->
    <div class="flex items-center gap-6">
      <nav
        class="hidden lg:flex items-center gap-7"
        aria-label="Navegación principal"
      >
        {
          navLinks.map(link => (
            <a
              href={link.href}
              class="text-sm font-bold text-(--hero-text) opacity-70 hover:opacity-100 transition-opacity"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Toggle -->
      <div class="flex items-center">
        <ThemeToggle client:load />
      </div>

      <!-- Hamburguesa -->
      <button id="menu-btn" class="lg:hidden p-2 text-(--hero-text)" aria-label="Abrir menú">
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="26"
          height="26"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="26"
          height="26"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="hidden absolute top-17.5 left-0 w-full bg-(--hero-bg) border-b border-(--border) px-6 py-5 shadow-lg lg:hidden cursor-pointer"
  >
    <nav class="flex flex-col gap-5">
      {
        navLinks.map(link => (
          <a
            href={link.href}
            class="mobile-link text-lg font-bold text-(--hero-text) opacity-80 hover:opacity-100 transition-opacity"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>

  <!-- Crear la caja que funcionara como el hover en cada uno de los menus -->
  <div
    id="menu-backdrop"
    class="absolute bg-black/5 backdrop-blur-lg rounded left-0 top-0 transition-all duration-500 ease-in-out opacity-0 -z-10"
    style="translate: var(--left) var(--top); width: var(--width); height: var(--height);"
  >
  </div>
</header>

<script src="./nav-script.ts"></script>
