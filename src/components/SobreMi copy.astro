<!-- <section id="sobre-mi" class="w-full py-4 transition-colors duration-300"> -->
<section
  id="sobre-mi"
  class="w-full flex items-center justify-center py-0 transition-colors duration-300"
>
  <div class="max-w-6xl mx-auto px-6 md:px-16 lg:px-24">
    <!-- Tag -->
    <div
      class="flex items-center gap-2 text-[11px] font-extrabold tracking-[2px] uppercase text-[var(--accent)] mb-3"
    >
      <span class="w-5 h-0.5 bg-[var(--accent)] rounded-full"></span>
      Sobre mí
    </div>

    <h2
      class="text-[clamp(2rem,4vw,3rem)] font-black tracking-[-1.5px] leading-[1.05] text-[var(--text)] mb-12"
    >
      El desarrollador<br /> detrás del código
    </h2>

    <!-- <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 lg:gap-16 items-start"> -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 lg:gap-16 items-start">
      <!-- Texto -->
      <div class="space-y-4 text-[15px] text-[var(--muted)] leading-[1.9]">
        <p>
          Soy <strong class="text-[var(--text)] font-bold"
            >Ingeniero en Sistemas Computacionales</strong
          >
          graduado en la Universidad de Guayaquil (Reg. SENESCYT: 1006-2017-1872471), con más de 10 años
          trabajando en el GAD Municipal de Naranjal como Analista de Sistemas.
        </p>
        <p>
          Tengo sistemas reales en producción:
          <strong class="text-[var(--text)] font-bold">SelNic</strong>, el sistema de gestión
          documental que uso día a día en mi trabajo, y estoy terminando <strong
            class="text-[var(--text)] font-bold">FutbolSystem</strong
          >, un sistema biométrico para ligas municipales con reconocimiento facial.
        </p>
        <p>
          Me despierto temprano a hacer ejercicios de lógica en
          <strong class="text-[var(--text)] font-bold">Exercism</strong>, aprendo continuamente y
          disfruto convertir procesos manuales en soluciones digitales eficientes.
        </p>
      </div>
      <!-- Lista de datos -->

      <div class="space-y-4 text-[15px] text-[var(--muted)] leading-[1.9]">
        <ul class="mt-6 space-y-3">
          {
            [
              "Naranjal, Guayas, Ecuador 🇪🇨",
              "Ing. Sistemas — Universidad de Guayaquil",
              "GAD Municipal Naranjal · Analista de Sistemas desde 2014",
              "Exercism.io · práctica diaria de algoritmos y lógica",
              "Inglés técnico · aprendizaje activo",
            ].map(item => (
              <li class="flex items-center gap-3 text-[14px]">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] flex-shrink-0" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
